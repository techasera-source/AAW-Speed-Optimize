datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// One row per real visitor page load, captured by the storefront beacon.
// metric is one of "LCP" | "INP" | "CLS". value is in milliseconds for
// LCP/INP and a unitless shift score (x1000, stored as int) for CLS.
model VitalSample {
  id        String   @id @default(cuid())
  shop      String
  metric    String
  value     Float
  path      String
  deviceType String  @default("unknown")
  createdAt DateTime @default(now())

  @@index([shop, metric, createdAt])
}
